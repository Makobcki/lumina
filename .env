# Core service URLs
LUMINA_INFERENCE_URL=http://inference:8001
LUMINA_QDRANT_URL=http://qdrant:6333
LUMINA_POSTGRES_DSN=postgresql://lumina:lumina@postgres:5432/lumina
LUMINA_GATEWAY_INDEX_URL=http://gateway:8000/index

# Public / local endpoints
LUMINA_GATEWAY_HEALTHCHECK_URL=http://localhost:8000/health
LUMINA_INFERENCE_HEALTHCHECK_URL=http://localhost:8001/health
LUMINA_QDRANT_HEALTHCHECK_URL=http://localhost:6333/healthz

# Logging
LUMINA_LOG_LEVEL=INFO

# RAG / LLM settings (Gateway /ask)
LUMINA_LLM_MODEL=gpt-4o-mini
LUMINA_LLM_API_KEY=
LUMINA_LLM_BASE_URL=
LUMINA_LLM_MAX_TOKENS=512
LUMINA_ASK_TOP_K=5
